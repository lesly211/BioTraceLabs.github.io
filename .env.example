# ============================================================
# OSINFOR - Configuración del entorno
# ============================================================
# Copia este archivo como .env y configura tus valores reales

# ---- API de Google Gemini (OBLIGATORIO para identificación real) ----
# Obtén tu clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=TU_API_KEY_AQUI

# ---- Configuración del servidor Flask ----
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=osinfor-secret-key-2024

# ---- Configuración de la aplicación ----
MAX_UPLOAD_MB=16
